{
  "name": "maintenance-planning-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "container:build": "node scripts/container-build.mjs",
    "container:run": "node scripts/container-run.mjs",
    "container:smoke": "node scripts/container-smoke.mjs",
    "db:migrate": "dotnet dotnet-ef database update --project src/MaintenancePlanning.Infrastructure/MaintenancePlanning.Infrastructure.csproj --startup-project src/MaintenancePlanning.Api/MaintenancePlanning.Api.csproj --context MaintenancePlanningDbContext",
    "db:smoke": "node scripts/database-smoke.mjs",
    "deploy:release-gate:dry-run": "node scripts/ecs-migration-release-gate.mjs --dry-run --cluster review-cluster --service review-api --subnets subnet-00000000000000000,subnet-11111111111111111 --security-groups sg-00000000000000000 --api-task-definition deploy/release/example-api-task-definition.json --migration-task-definition deploy/release/example-migration-task-definition.json",
    "guard": "node scripts/quality-guards.mjs all",
    "guard:artifacts": "node scripts/quality-guards.mjs artifacts",
    "guard:public-docs": "node scripts/quality-guards.mjs public-docs",
    "guard:secrets": "node scripts/quality-guards.mjs secrets",
    "infra:validate": "node scripts/terraform-validate.mjs",
    "migration:bundle": "node scripts/build-migration-bundle.mjs",
    "migration:container:build": "node scripts/migration-container-build.mjs",
    "release:gate:test": "node scripts/ecs-release-gate-tests.mjs",
    "test:reviewer-evidence": "node scripts/reviewer-evidence-smoke.mjs",
    "verify": "node scripts/quality-guards.mjs all && node scripts/reviewer-evidence-smoke.mjs && node scripts/ecs-release-gate-tests.mjs",
    "worker:container:build": "node scripts/worker-container-build.mjs"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.18.3"
}
